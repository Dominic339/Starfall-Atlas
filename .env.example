# ============================================================
# Starfall Atlas — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase — required for all environments
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
# ------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used by Next.js API routes to bypass RLS for game state writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Admin access
# Comma-separated list of Supabase auth.users UUIDs that have
# access to the /admin route group.
# Leave empty to disable admin access entirely.
# ------------------------------------------------------------

ADMIN_AUTH_IDS=

# ------------------------------------------------------------
# Optional: Payment provider (for premium shop)
# Not required until Phase 11.
# ------------------------------------------------------------

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
